// The models are yours to design (see the project spec for the game rules).
// After adding or changing a model, run:  yarn prisma:migrate
// Prisma 7 note: the connection URL lives in `prisma.config.ts`, not here.
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model Answers {
  answer_id String  @id @db.Uuid
  game_id   String?
  username  String?
  answer    String?
  Game      Game    @relation(fields: [answer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_answer_id")
}

model Game {
  id        String   @id @db.Uuid
  room_code String?
  letter    String?  @db.Char
  topic     String?
  Answers   Answers?
}
