// Prisma 7 note: the connection URL lives in `prisma.config.ts`, not here.
// Docs: https://www.prisma.io/docs

// api/prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  roomCode    String   @id 
  currentName String?   
  players     String[]
  celebrity_answers String[]
}

model Player {
  id        String   @id 
  username  String
  score     Int      @default(0)
}

model Celebrity {
  id        String   @id @default(cuid())
  name      String
  used      Boolean  @default(false)
}